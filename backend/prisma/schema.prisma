generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(TENANT)
  createdAt DateTime @default(now())
  bookings  Booking[]
}

model House {
  id            String   @id @default(uuid())
  title         String
  description   String
  price         Float
  location      String
  neighbourhood String
  bedrooms      Int
  bathrooms     Int
  images        String[]
  available     Boolean  @default(true)
  landlordName  String
  landlordPhone String
  createdAt     DateTime @default(now())
  bookings      Booking[]
}

model Booking {
  id        String        @id @default(uuid())
  user      User          @relation(fields: [userId], references: [id])
  userId    String
  house     House         @relation(fields: [houseId], references: [id])
  houseId   String
  status    BookingStatus @default(PENDING)
  visitDate DateTime
  createdAt DateTime      @default(now())
  payment   Payment?
}

model Payment {
  id        String        @id @default(uuid())
  booking   Booking       @relation(fields: [bookingId], references: [id])
  bookingId String        @unique
  amount    Float
  mpesaCode String?
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())
}

enum Role {
  TENANT
  LANDLORD
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}
